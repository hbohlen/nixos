{
  "servers": {
    "byterover-mcp": {
      "type": "http",
      "url": "https://mcp.byterover.dev/mcp?machineId=1f09bab5-49e9-6fc0-aec6-ee0ca0e72f9a"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${input:github_mcp_pat}"
      }
    },
    "nixos": {
      "command": "uvx",
      "args": ["mcp-nixos"]
    }
  },
  "inputs": [
    {
      "type": "promptString",
      "id": "github_mcp_pat",
      "description": "GitHub Personal Access Token",
      "password": true
    }
  ]
}
