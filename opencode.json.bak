{
  "providers": {
    "openai": {
      "disabled": false
    },
    "anthropic": {
      "disabled": false
    }
  },
  "agents": {
    "coder": {
      "model": "claude-4-sonnet",
      "maxTokens": 8000,
      "reasoningEffort": "high"
    },
    "task": {
      "model": "gpt-4o",
      "maxTokens": 4000,
      "reasoningEffort": "medium"
    },
    "title": {
      "model": "claude-3.5-sonnet",
      "maxTokens": 80,
      "reasoningEffort": "low"
    },
    "summarizer": {
      "model": "gpt-4o",
      "maxTokens": 2000,
      "reasoningEffort": "medium"
    }
  },
  "data": {
    "directory": ".opencode"
  },
  "autoCompact": true,
  "lsp": {
    "nix": {
      "command": "nil",
      "args": [],
      "disabled": false
    }
  },
  "tui": {
    "theme": "opencode"
  },
  "shell": {
    "path": "/bin/bash",
    "args": ["-l"]
  },
  "mcpServers": {
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/sse",
      "type": "remote"
    }
  },
  "contextPaths": [
    "AGENTS.md",
    "brief.md"
  ],
  "projectInfo": {
    "name": "NixOS Configuration",
    "description": "Modern, declarative, and ephemeral NixOS system with ZFS, Impermanence, and Hyprland",
    "structure": {
      "flake.nix": "Central flake entry point",
      "hosts/": "Host-specific configurations",
      "modules/nixos/": "Reusable NixOS modules",
      "modules/home-manager/": "Reusable Home Manager modules",
      "users/": "User accounts and configurations",
      "secrets/": "Encrypted secret files",
      "scripts/": "Helper scripts for common tasks"
    },
    "commands": {
      "rebuild": "./scripts/rebuild.sh",
      "test": "nixos-rebuild build --flake .#$(hostname)",
      "check": "nix flake check"
    },
    "technologies": [
      "NixOS",
      "Nix Flakes",
      "ZFS",
      "LUKS",
      "Impermanence",
      "Hyprland",
      "Home Manager",
      "Opnix"
    ]
  }
}